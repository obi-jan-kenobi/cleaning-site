---
import { Phone, Mail, Menu, X, MessageCircle } from '@lucide/astro';
import "../styles/global.css";
import Logo from "../images/logo.svg";

interface Props {
  title: string;
  description: string;
  jsonLd?: object;
}

const { title, description, jsonLd } = Astro.props;

const BRAND = {
  name: "EMSIG Gebäudedienste GmbH",
  tagline: "Schleswig-Holsteins gründlicher Reinigungsservice",
  phone: "+49 4621 930245",
  email: "info@emsig-gd.de",
  area: "Schleswig-Holstein",
  address: "Husumer Baum 36, 24837 Schleswig",
  legal: { impressum: "/impressum", datenschutz: "/datenschutz" },
  jobs: "/stellenangebote",
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-cover.jpg" />
    <meta name="theme-color" content="#4299f0" />
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen bg-background-light text-text-main-light overflow-x-hidden transition-colors duration-200">
    <!-- Header -->
    <header class="sticky top-0 z-50 w-full bg-surface-light/95 backdrop-blur border-b border-gray-200">
      <div class="px-4 md:px-10 py-3 max-w-[1280px] mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-primary">
          <div class="size-10 flex items-center justify-center rounded-lg bg-primary/10">
            <Logo class="h-6 w-6 text-primary" />
          </div>
          <span class="text-text-main-light text-xl font-bold leading-tight tracking-tight">{BRAND.name}</span>
        </a>
        
        <div class="hidden md:flex flex-1 justify-end gap-8 items-center">
          <nav class="flex items-center gap-9">
            <a class="text-text-main-light text-sm font-medium hover:text-primary transition-colors" href="/">Start</a>
            <a class="text-text-main-light text-sm font-medium hover:text-primary transition-colors" href="/#services">Services</a>
            <a class="text-text-main-light text-sm font-medium hover:text-primary transition-colors" href="/#about">Über uns</a>
            <a class="text-text-main-light text-sm font-medium hover:text-primary transition-colors" href={BRAND.jobs}>Stellenangebote</a>
            <!-- <a class="text-text-main-light text-sm font-medium hover:text-primary transition-colors" href="/#reviews">Bewertungen</a> -->
            <a class="text-text-main-light text-sm font-medium hover:text-primary transition-colors" href="/#contact">Kontakt</a>
          </nav>
          <a href="/#contact">
            <button class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary hover:bg-primary-hover transition-all text-white text-sm font-bold leading-normal tracking-wide">
              <span class="truncate">Angebot anfragen</span>
            </button>
          </a>
        </div>
        
        <button id="mobile-menu-btn" class="md:hidden p-2 text-text-main-light" aria-label="Menü öffnen">
          <Menu class="h-6 w-6" />
        </button>
      </div>
    </header>
    
    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu-overlay" class="fixed inset-0 bg-black/50 z-50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"></div>
    
    <!-- Mobile Menu Drawer -->
    <nav id="mobile-menu" class="fixed top-0 right-0 h-full w-[280px] bg-white z-50 shadow-2xl transform translate-x-full transition-transform duration-300 ease-out md:hidden">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <span class="text-text-main-light text-lg font-bold">Menü</span>
        <button id="mobile-menu-close" class="p-2 text-text-main-light hover:text-primary transition-colors" aria-label="Menü schließen">
          <X class="h-6 w-6" />
        </button>
      </div>
      <div class="flex flex-col p-4">
        <a class="py-3 text-text-main-light font-medium hover:text-primary transition-colors border-b border-gray-100" href="/">Start</a>
        <a class="py-3 text-text-main-light font-medium hover:text-primary transition-colors border-b border-gray-100" href="/#services">Services</a>
        <a class="py-3 text-text-main-light font-medium hover:text-primary transition-colors border-b border-gray-100" href="/#about">Über uns</a>
        <a class="py-3 text-text-main-light font-medium hover:text-primary transition-colors border-b border-gray-100" href={BRAND.jobs}>Stellenangebote</a>
        <a class="py-3 text-text-main-light font-medium hover:text-primary transition-colors border-b border-gray-100" href="/#contact">Kontakt</a>
        <a href="/#contact" class="mt-6">
          <button class="w-full flex items-center justify-center rounded-lg h-12 px-4 bg-primary hover:bg-primary-hover transition-all text-white text-sm font-bold">
            <span>Angebot anfragen</span>
          </button>
        </a>
        <div class="mt-8 pt-6 border-t border-gray-200">
          <a href={`tel:${BRAND.phone.replace(/\s/g,"")}`} class="flex items-center gap-3 py-2 text-text-sub-light hover:text-primary transition-colors">
            <Phone class="h-5 w-5" />
            <span class="text-sm">{BRAND.phone}</span>
          </a>
          <a href={`mailto:${BRAND.email}`} class="flex items-center gap-3 py-2 text-text-sub-light hover:text-primary transition-colors">
            <Mail class="h-5 w-5" />
            <span class="text-sm">{BRAND.email}</span>
          </a>
        </div>
      </div>
    </nav>
    
    <script>
      // Mobile Menu Toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const menuClose = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuOverlay = document.getElementById('mobile-menu-overlay');
      
      function openMenu() {
        mobileMenu?.classList.remove('translate-x-full');
        menuOverlay?.classList.remove('opacity-0', 'pointer-events-none');
        document.body.style.overflow = 'hidden';
      }
      
      function closeMenu() {
        mobileMenu?.classList.add('translate-x-full');
        menuOverlay?.classList.add('opacity-0', 'pointer-events-none');
        document.body.style.overflow = '';
      }
      
      menuBtn?.addEventListener('click', openMenu);
      menuClose?.addEventListener('click', closeMenu);
      menuOverlay?.addEventListener('click', closeMenu);
      
      // Close menu when clicking a link
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
      
      // Close on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });
    </script>

    <slot />

    <!-- Footer -->
    <footer class="bg-surface-light border-t border-gray-200 pt-16 pb-8">
      <div class="max-w-[1280px] mx-auto px-4 md:px-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
          <!-- Brand -->
          <div class="flex flex-col gap-4">
            <a href="/" class="flex items-center gap-2 text-primary">
              <div class="size-6 flex items-center justify-center rounded bg-primary/10">
                <Logo class="h-4 w-4 text-primary" />
              </div>
              <span class="text-text-main-light text-lg font-bold">{BRAND.name}</span>
            </a>
            <p class="text-text-sub-light text-sm">Sauberkeit, auf die Sie sich verlassen können – in {BRAND.area} und Umgebung.</p>
            <div class="flex gap-4 mt-2">
              <a class="text-text-sub-light hover:text-primary transition-colors" href={`mailto:${BRAND.email}`}>
                <Mail class="h-5 w-5" />
              </a>
              <a class="text-text-sub-light hover:text-primary transition-colors" href={`tel:${BRAND.phone.replace(/\s/g,"")}`}>
                <Phone class="h-5 w-5" />
              </a>
            </div>
          </div>
          
          <!-- Company -->
          <div>
            <h3 class="text-text-main-light font-bold mb-4">Unternehmen</h3>
            <ul class="flex flex-col gap-2 text-sm text-text-sub-light">
              <li><a class="hover:text-primary transition-colors" href="/#about">Über uns</a></li>
              <li><a class="hover:text-primary transition-colors" href={BRAND.jobs}>Stellenangebote</a></li>
              <li><a class="hover:text-primary transition-colors" href="/#contact">Kontakt</a></li>
              <li><a class="hover:text-primary transition-colors" href={BRAND.legal.impressum}>Impressum</a></li>
              <li><a class="hover:text-primary transition-colors" href={BRAND.legal.datenschutz}>Datenschutz</a></li>
            </ul>
          </div>
          
          <!-- Services -->
          <div>
            <h3 class="text-text-main-light font-bold mb-4">Services</h3>
            <ul class="flex flex-col gap-2 text-sm text-text-sub-light">
              <li><a class="hover:text-primary transition-colors" href="/leistungen/bueroreinigung">Büroreinigung</a></li>
              <li><a class="hover:text-primary transition-colors" href="/leistungen/glasreinigung">Glasreinigung</a></li>
              <li><a class="hover:text-primary transition-colors" href="/leistungen/fassadenreinigung">Fassadenreinigung</a></li>
              <li><a class="hover:text-primary transition-colors" href="/leistungen/baureinigung">Baureinigung</a></li>
              <li><a class="hover:text-primary transition-colors" href="/leistungen/pv-reinigung">PV-Reinigung</a></li>
              <li><a class="hover:text-primary transition-colors" href="/#services">Alle Services</a></li>
            </ul>
          </div>
          
          <!-- Contact -->
          <div>
            <h3 class="text-text-main-light font-bold mb-4">Kontakt</h3>
            <div class="flex flex-col gap-3 text-sm text-text-sub-light">
              <div class="flex items-center gap-2">
                <Phone class="h-4 w-4" />
                <a class="hover:text-primary transition-colors" href={`tel:${BRAND.phone.replace(/\s/g,"")}`}>{BRAND.phone}</a>
              </div>
              <div class="flex items-center gap-2">
                <Mail class="h-4 w-4" />
                <a class="hover:text-primary transition-colors" href={`mailto:${BRAND.email}`}>{BRAND.email}</a>
              </div>
              <p class="text-xs mt-2">{BRAND.address}</p>
            </div>
          </div>
        </div>
        
        <div class="border-t border-gray-200 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-text-sub-light text-sm text-center md:text-left">
            © {new Date().getFullYear()} {BRAND.name}. Alle Rechte vorbehalten.
          </p>
          <div class="flex gap-6 text-sm font-medium text-text-sub-light">
            <a class="hover:text-primary" href={BRAND.legal.impressum}>Impressum</a>
            <a class="hover:text-primary" href={BRAND.legal.datenschutz}>Datenschutz</a>
          </div>
        </div>
      </div>
    </footer>
    
    <!-- Floating Contact Button -->
    <div class="fixed bottom-6 right-6 z-40">
      <a href="/#contact" class="w-14 h-14 rounded-full bg-primary text-white shadow-lg hover:scale-110 transition-transform flex items-center justify-center">
        <MessageCircle class="h-7 w-7" />
      </a>
    </div>

  </body>
</html>
