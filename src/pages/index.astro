---
import Layout from "../layouts/Layout.astro";
import { Picture } from 'astro:assets';
import map from "../images/map.png";
/* Note: Using external Gemini-generated images for hero carousel */

const heroImages = [
  { 
    url: "https://lh3.googleusercontent.com/aida-public/AB6AXuCKsU8lgmnXPzzrWVXFEsT_Gt30nUf9w4eVXYX-huWg8jgoIcAkCV9RpXaBqERH5yM2oaIO1mv8esaHPgRC5eKKm49JwuiTWou3HxFB5z-DfprmIF7No3E4t5Pqn2UmEc0QRBFB5ZfKIiZna78xSex8nSEzOO7_acN5-y7XXp2O8S2dClOg-QlQ3A00KwRdG48TEtZP57WAHtsG0gb8wAuGi0mblLtMY-0fNq5eQ_JTGAz04bMi5uIZ8pOJNXoR_MsOeKg03VJC9V4l",
    alt: "Helles modernes Wohnzimmer mit sauberem weißen Sofa"
  },
  { 
    url: "https://lh3.googleusercontent.com/aida-public/AB6AXuDdzkhJAAMxeFhZufsKWVYXCTBN8TYuOxxjgyokGb4oXK4qAsJnLMnbVek70VLh_sbqttBW8Fbz6xTNHb7ACnLUtUX6fAO9yn2ZfwPwjE-9xV2r3u5BGDvVcGsusz3C7iEJqjCOTKgWfiES1u3Z24pqjdLP-b6OSHgek6GQve71nguVhR_-2MmUFPyxxedbSXrtzVbTFDDpQQ5P5N3YON_bzSE836aaA0Bs3JE_m3gspCYK8ju8otHcYI6dGj50W8_gjWTiCo4JWUfv",
    alt: "Professionelle Unterhaltsreinigung"
  },
  { 
    url: "https://lh3.googleusercontent.com/aida-public/AB6AXuBIobvE226hPajiCAzfBowDzHhGCthhR7e38_xlj2a4MJya8fQvXEE925VbWHENoS8PTthAgBhPtedob1zQOaLmKrFwEWh5Ky8yhs99b2ZxW41Ny9cj3AX6Ch9JgZzaOIgoSlO-ypO2fjsvPbSfz80O2-KZ3M2ZjZG_6c4Y10FTXi-_R32-HkdABJmsVOFKPGhzMUXmFjksE6yZF9f751046OwmwJjTjSD4GQ-Jh0LbldAN84ohtD-bMWWCmKXXsLFDriaPO08k00cU",
    alt: "Gründliche Tiefenreinigung"
  },
  { 
    url: "https://lh3.googleusercontent.com/aida-public/AB6AXuBxjI5tNvV29wIw8uR17YYm-ChtS8r3VLbwAZScY0rszIGzR8SGqiKcbAnCSMq91bEOMs84SKLa3RHLxTBVf4Gr472tBbe09r4JRS6e9qJ8IDbpVOzBPECgizvjcUOcqTDa3TLsiTD-gVFB2qNym-INdbo1qcdhbkcZpXPDLpLGWtZ1Yl9t2xu6v5Oj81gmBFWuXECpQyufryM5n2twQ7i_NAb6UD8RnIZImEZNxi6dYUn7yl4V6OZG8KcUIK6ICcorDzy6lHbuHkbC",
    alt: "Professionelle Büroreinigung"
  },
  { 
    url: "https://lh3.googleusercontent.com/aida-public/AB6AXuCxKKxxIhSNEvKuTKPOmc7IxkgpVVOSuyFvzKMd_Z8tijSE4jn2p1DvxKSpsd9ZyEvN-myc3P5x3OuzqkcRUzv3jV3hkHOGROGonm5n0vfPcY2nTXSRK7z9QbZrEE118VXoVYhdJW61lqbymTJvHyl7ni8Z0slMip1xmnDjXQxjg2ZN95ZweX1wYA9VjY-yP9v-fQ-T3IOmELo65lqVef-KMgubPKlxCIQqSAb1nMMTdrrINHqx9RV06Xv3GoMKoYXUkHa-EJZFBW4J",
    alt: "Entspannung im sauberen Zuhause"
  },
];

const BRAND = {
  name: "EMSIG Gebäudedienste GmbH",
  tagline: "Schleswig-Holsteins gründlicher Reinigungsservice",
  phone: "+49 4621 830245",
  email: "info@emsig-gd.de",
  area: "Schleswig-Holstein",
  address: "Husumer Baum 36, 24837 Schleswig",
};

const title = `${BRAND.name} – ${BRAND.tagline}`;
const description = `${BRAND.name}: Unterhalts-, Büro-, Glas-, PV- & Baureinigung in ${BRAND.area}. Schnelle Terminvergabe, versichert & zuverlässig.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: BRAND.name,
  image: ["/logo.svg"],
  address: {
    "@type": "PostalAddress",
    streetAddress: BRAND.address,
    addressLocality: "Schleswig",
    addressRegion: "SH",
    postalCode: "24837",
    addressCountry: "DE",
  },
  url: "https://emsig.sh/",
  telephone: BRAND.phone,
  areaServed: [
    "Kiel",
    "Lübeck",
    "Flensburg",
    "Neumünster",
    "Norderstedt",
    "Pinneberg",
    "Lübecker Bucht",
    "Kieler Bucht",
    "Schleswig"
  ],
  sameAs: ["#", "#"],
  openingHours: "Mo-Fr 08:00-18:00",
  makesOffer: [
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Unterhaltsreinigung" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Büroreinigung" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Glasreinigung" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Baureinigung" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Photovoltaikreinigung" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Gartenpflege" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Fassadenreinigung" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Winterdienst" } },
    { "@type":"Offer", itemOffered:{ "@type":"Service", name:"Entrümpelung" } }
  ]
};

const services = [
  { title: "Unterhaltsreinigung", icon: "home_work", desc: "Regelmäßig oder einmalig – Küche, Bad, Böden & mehr." },
  { title: "Büroreinigung", icon: "desk", desc: "Arbeitsplätze, Sanitär, Küche & Besprechungsräume." },
  { title: "Fenster & Glas", icon: "window", desc: "Streifenfrei innen & außen, inkl. Rahmen." },
  { title: "Grund- & Umzug", icon: "box", desc: "Intensivreinigung inkl. Kühlschrank, Backofen & Fenster." },
  { title: "Baureinigung", icon: "construction", desc: "Grob- und Feinreinigung nach Renovierung/Neubau." },
  { title: "PV-Reinigung", icon: "solar_power", desc: "Schonende Reinigung Ihrer Photovoltaik-Module." },
  { title: "Gartenpflege", icon: "grass", desc: "Rasen, Hecken, Beete – regelmäßig oder einmalig." },
  { title: "Winterdienst", icon: "ac_unit", desc: "Schneeräumen & Streuen nach Satzung." },
];

const reviews = [
  { name: "Lena H.", role: "Privathaushalt", text: "Sehr zuverlässig und super Ergebnis. Unsere Fenster haben noch nie so geglänzt!" },
  { name: "Markus K.", role: "Hausbesitzer", text: "Kurzfristig einen Termin bekommen, freundlich & gründlich – absolute Empfehlung." },
  { name: "Office West GmbH", role: "Geschäftskunde", text: "Top Büroreinigung. Transparent, flexibel und pünktlich." },
];

const faqs = [
  { q: "Bringen Sie Material mit?", a: "Ja – gern. Auf Wunsch verwenden wir Ihre bevorzugten Mittel." },
  { q: "Gibt es eine Mindestdauer?", a: "Für Haushaltsreinigung 2 Stunden, für Grund-/Umzug je nach Objekt." },
  { q: "Wie läuft die Bezahlung?", a: "Per Rechnung, EC oder Bar. Geschäftskunden erhalten monatliche Sammelrechnungen." },
  { q: "Sind Sie versichert?", a: "Ja. Schäden sind über unsere Betriebshaftpflicht abgedeckt." },
];
---

<Layout title={title} description={description} jsonLd={jsonLd} showHomeNav={true}>
  <!-- Hero Section -->
  <section class="relative w-full py-12 md:py-20 lg:py-24 bg-gradient-to-br from-blue-50 to-white">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="flex flex-col-reverse lg:flex-row gap-10 items-center">
        <div class="flex flex-col gap-6 lg:w-1/2 items-start text-left">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wide">
            <span class="material-symbols-outlined text-[16px]">verified</span>
            Geprüft & Versichert
          </div>
          <h1 class="text-text-main-light text-4xl md:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight">
            {BRAND.name}
          </h1>
          <h2 class="text-text-sub-light text-lg md:text-xl font-normal leading-relaxed max-w-[540px]">
            {BRAND.tagline}. Unterhalts-, Büro-, Glas- & Baureinigung in {BRAND.area}. Pünktlich, freundlich und mit Zufriedenheitsversprechen.
          </h2>
          <div class="flex flex-col sm:flex-row w-full max-w-[480px] gap-3 mt-4">
            <a href="#contact" class="flex-grow">
              <button class="w-full h-14 px-8 rounded-lg bg-primary hover:bg-primary-hover text-white text-base font-bold shadow-lg shadow-blue-500/30 transition-all flex items-center justify-center gap-2 whitespace-nowrap">
                <span>Kostenloses Angebot</span>
                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
              </button>
            </a>
            <a href={`tel:${BRAND.phone.replace(/\s/g,"")}`}>
              <button class="h-14 px-6 rounded-lg border border-gray-300 hover:bg-gray-50 text-text-main-light text-base font-medium transition-all flex items-center justify-center gap-2 whitespace-nowrap">
                <span class="material-symbols-outlined text-[20px]">call</span>
                <span>{BRAND.phone}</span>
              </button>
            </a>
          </div>
          <div class="flex flex-wrap items-center gap-4 mt-6 text-sm text-text-sub-light">
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-green-500 text-[18px]">check_circle</span>
              <span>Versichert & zuverlässig</span>
            </div>
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-green-500 text-[18px]">check_circle</span>
              <span>Flexibel & kurzfristig</span>
            </div>
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-green-500 text-[18px]">check_circle</span>
              <span>100% Zufriedenheit</span>
            </div>
          </div>
        </div>
        <div class="lg:w-1/2 w-full relative">
          <!-- Hero Carousel -->
          <div class="aspect-[4/3] w-full rounded-2xl overflow-hidden shadow-2xl bg-gray-200 relative" id="hero-carousel">
            {heroImages.map((img, i) => (
              <div 
                class={`carousel-slide absolute inset-0 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
                data-index={i}
              >
                <img 
                  src={img.url} 
                  alt={img.alt} 
                  class="w-full h-full object-cover"
                  loading={i === 0 ? "eager" : "lazy"}
                />
              </div>
            ))}
            <!-- Carousel Indicators -->
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20">
              {heroImages.map((_, i) => (
                <button 
                  class={`carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ${i === 0 ? 'bg-white w-8' : 'bg-white/50 hover:bg-white/75'}`}
                  data-index={i}
                  aria-label={`Bild ${i + 1}`}
                />
              ))}
            </div>
            <!-- Navigation Arrows -->
            <button class="carousel-prev absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white shadow-lg flex items-center justify-center z-20 transition-all opacity-0 group-hover:opacity-100">
              <span class="material-symbols-outlined text-text-main-light">chevron_left</span>
            </button>
            <button class="carousel-next absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white shadow-lg flex items-center justify-center z-20 transition-all opacity-0 group-hover:opacity-100">
              <span class="material-symbols-outlined text-text-main-light">chevron_right</span>
            </button>
          </div>
          <div class="absolute -bottom-6 -left-6 md:bottom-10 md:-left-10 bg-white p-4 rounded-xl shadow-xl z-20 flex items-center gap-3 animate-bounce" style="animation-duration: 3s;">
            <div class="bg-green-100 p-2 rounded-full">
              <span class="material-symbols-outlined text-green-600">sentiment_satisfied</span>
            </div>
            <div>
              <p class="font-bold text-sm text-text-main-light">100% Zufriedenheit</p>
              <p class="text-xs text-text-sub-light">Garantierter Service</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="py-6 bg-surface-light border-y border-gray-200">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-sub-light">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-[20px]">star</span>
          <span>Volle Kundenzufriedenheit</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-[20px]">verified_user</span>
          <span>Geprüft & versichert</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-[20px]">eco</span>
          <span>Nachhaltige Reinigungsmittel</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-[20px]">schedule</span>
          <span>Schnelle Terminvergabe</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 md:py-24 bg-surface-light" id="services">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="max-w-[600px]">
          <h2 class="text-primary text-sm font-bold uppercase tracking-wider mb-2">Unsere Services</h2>
          <h3 class="text-3xl md:text-4xl font-bold text-text-main-light mb-4">Flexibel für Ihre Bedürfnisse</h3>
          <p class="text-text-sub-light text-lg">Wählen Sie, was Sie brauchen – ohne langfristige Bindung. Von der regelmäßigen Reinigung bis zur Spezialreinigung.</p>
        </div>
        <a class="text-primary font-bold flex items-center hover:underline" href="#contact">
          Alle Services anfragen
          <span class="material-symbols-outlined text-[20px] ml-1">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service) => (
          <div class="group flex flex-col rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-primary shrink-0">
                  <span class="material-symbols-outlined text-[22px]">{service.icon}</span>
                </div>
                <h4 class="text-lg font-bold text-text-main-light">{service.title}</h4>
              </div>
              <p class="text-text-sub-light text-sm leading-relaxed mb-5 flex-1">{service.desc}</p>
              <a href="#contact" class="w-full py-2.5 rounded-lg border border-primary/20 hover:border-primary hover:bg-primary/5 text-primary font-bold text-sm transition-colors flex items-center justify-center gap-2">
                  Angebot anfragen
                </a>
              </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 md:py-24 bg-blue-50/50" id="about">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="bg-white rounded-3xl p-6 md:p-12 shadow-sm border border-gray-100">
        <div class="flex flex-col lg:flex-row gap-12 items-center">
          <div class="lg:w-1/2 flex flex-col gap-6">
            <div class="inline-flex items-center gap-2 text-primary font-bold uppercase text-sm tracking-wider">
              <span class="w-8 h-[2px] bg-primary"></span>
              Über EMSIG
            </div>
            <h3 class="text-3xl md:text-4xl font-bold text-text-main-light leading-tight">
              Mehr als nur ein Reinigungsservice. Wir sind Ihr Partner für Sauberkeit.
            </h3>
            <p class="text-text-sub-light text-lg leading-relaxed">
              Unser geprüftes Team sorgt dafür, dass Ihre Räume in sicheren Händen sind. Wir verwenden ausschließlich umweltfreundliche Produkte. Saubere Räume bedeuten ein klares Gefühl – und mehr Zeit für die wichtigen Dinge im Leben.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">eco</span>
                <span class="text-text-main-light font-medium">Umweltfreundliche Produkte</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">verified_user</span>
                <span class="text-text-main-light font-medium">Geprüftes Personal</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">schedule</span>
                <span class="text-text-main-light font-medium">Flexible Terminplanung</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">pets</span>
                <span class="text-text-main-light font-medium">Tierfreundlich</span>
              </div>
            </div>
            <a href="#contact" class="mt-4 flex items-center justify-center rounded-lg h-12 px-6 bg-gray-100 hover:bg-gray-200 text-text-main-light text-sm font-bold w-fit transition-colors">
              Jetzt Kontakt aufnehmen
            </a>
          </div>
          <div class="lg:w-1/2 w-full">
            <div class="aspect-[4/3] w-full rounded-2xl overflow-hidden shadow-lg">
              <Picture src={map} formats={['avif', 'webp']} alt="Einsatzgebiet Schleswig-Holstein" class="w-full h-full object-cover" />
            </div>
            <p class="mt-4 text-center text-sm text-text-sub-light">
              Unser Einsatzgebiet: {BRAND.area} (Kiel, Lübeck, Flensburg, Neumünster, u.v.m.)
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="py-16 md:py-24 bg-surface-light" id="reviews">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="text-center max-w-[720px] mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-text-main-light mb-4">Was Kund:innen sagen</h2>
        <p class="text-text-sub-light text-lg">Echte Rückmeldungen aus Schleswig-Holstein.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.map((review) => (
          <div class="p-8 rounded-xl bg-background-light flex flex-col gap-4 relative">
            <span class="material-symbols-outlined text-primary/20 text-[48px] absolute top-6 right-6">format_quote</span>
            <div class="flex gap-1 text-yellow-400">
              {[1,2,3,4,5].map(() => (
                <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
              ))}
            </div>
            <p class="text-text-main-light italic">"{review.text}"</p>
            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-gray-200">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold">
                {review.name.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-bold text-text-main-light">{review.name}</p>
                <p class="text-xs text-text-sub-light">{review.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-16 md:py-24 bg-blue-50/50">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="text-center max-w-[720px] mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-text-main-light mb-4">Häufige Fragen</h2>
        <p class="text-text-sub-light text-lg">Nicht fündig geworden? Schreiben Sie uns – wir antworten schnell.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6" itemscope itemtype="https://schema.org/FAQPage">
        {faqs.map((faq) => (
          <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3 class="text-lg font-semibold text-text-main-light flex items-start gap-3" itemprop="name">
              <span class="material-symbols-outlined text-primary mt-0.5">help</span>
              {faq.q}
            </h3>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p class="mt-2 text-text-sub-light pl-9" itemprop="text">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 md:py-24 bg-surface-light" id="contact">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-start">
        <div class="lg:w-5/12 flex flex-col gap-6">
          <div class="inline-flex items-center gap-2 text-primary font-bold uppercase text-sm tracking-wider">
            <span class="w-8 h-[2px] bg-primary"></span>
            Kontakt aufnehmen
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-text-main-light leading-tight">
            Bereit für strahlende Sauberkeit?
          </h2>
          <p class="text-text-sub-light text-lg leading-relaxed">
            Beschreiben Sie kurz Ihr Objekt und Wunsch-Termin. Wir melden uns schnell mit einem kostenlosen Angebot zurück.
          </p>
          <div class="flex flex-col gap-6 mt-4">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center text-primary shadow-sm border border-gray-100">
                <span class="material-symbols-outlined">call</span>
              </div>
        <div>
                <p class="text-sm text-text-sub-light font-medium">Telefon</p>
                <a href={`tel:${BRAND.phone.replace(/\s/g,"")}`} class="text-lg font-bold text-text-main-light hover:text-primary">{BRAND.phone}</a>
              </div>
            </div>
            <div class="flex items-center gap-4">
