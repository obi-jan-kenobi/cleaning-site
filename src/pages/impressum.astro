---
import Layout from "../layouts/Layout.astro";

const BRAND = {
  name: "EMSIG Gebäudedienste",
};

const title = `Impressum – ${BRAND.name}`;
const description = `Impressum und rechtliche Hinweise von ${BRAND.name}`;
---

<Layout title={title} description={description}>
  <!-- Main Content -->
  <main class="py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-3xl font-bold tracking-tight mb-8">Impressum</h1>
        
        <div class="prose prose-lg max-w-none">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-6">Angaben gemäß § 5 TMG</h2>
          
          <div class="space-y-6">
            <div>
              <h3 class="text-xl font-semibold mb-2">Firmenname</h3>
              <p class="text-lg">EMSIG Gebäudedienste GmbH</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold mb-2">Anschrift</h3>
              <p class="text-lg">Husumer Baum 36<br>24837 Schleswig</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold mb-2">Geschäftsführer</h3>
              <p class="text-lg">Peter Lapzien<br>Husumer Baum 36<br>24837 Schleswig<br>E-Mail: info@emsig-gd.de</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold mb-2">Kontakt</h3>
              <p class="text-lg">E-Mail: info@emsig-gd.de</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold mb-2">Registergericht</h3>
              <p class="text-lg">Amtsgericht Flensburg</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold mb-2">Registernummer</h3>
              <p class="text-lg">HR B 8215 FL</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold mb-2">Umsatzsteueridentifikationsnummer</h3>
              <p class="text-lg">207 215 206</p>
            </div>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t">
          <a href="/" class="inline-flex items-center text-primary hover:text-primary-hover font-medium">
            ← Zurück zur Startseite
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
