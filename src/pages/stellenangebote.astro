---
import Layout from "../layouts/Layout.astro";
import { Briefcase, Mail, Phone, CircleCheck, Clock, Shield, ArrowRight, MessageCircle, Smartphone } from "@lucide/astro";

const BRAND = {
  name: "EMSIG Gebäudedienste GmbH",
  email: "info@emsig-gd.de",
  phone: "+49 4621 930245",
  mobile: "+49 157 30676432",
};

const mobileDigits = BRAND.mobile.replace(/\D/g, "");
const whatsappHref = `https://wa.me/${mobileDigits}`;
const mobileTelHref = `tel:+${mobileDigits}`;

const title = `Stellenangebote – ${BRAND.name}`;
const description = `Karriere bei ${BRAND.name}: Jobs in der Gebäudereinigung in Schleswig-Holstein. Bewirb dich jetzt – faire Bezahlung, festes Team, geprüfter Arbeitgeber.`;

const benefits = [
  "Faire Vergütung und pünktliche Auszahlung",
  "Einarbeitung durch erfahrene Kolleg:innen",
  "Geprüftes, freundliches Team",
  "Einsatz in Schleswig-Holstein, vor allem in der Region Schleswig, Kreis Schleswig-Flensburg, Flensburg, übriges nördliches Schleswig-Holstein",
];

const openings = [
  {
    title: "Reinigungskraft (m/w/d)",
    type: "Ab Ende April 2026 bis Ende Oktober 2026 · täglich Mo–Sa",
    text: "Unterhaltsreinigung für ein Objekt in Mittelangeln (Satrup) ab Ende April 2026 bis Oktober 2026, täglich montags bis samstags, jeweils 2 Stunden – entweder um 06:00 Uhr oder ab 20:00 Uhr (nach Absprache). Zuverlässigkeit und Sorgfalt sind uns wichtiger als lange Berufserfahrung – wir bringen dir alles bei. Ansprechpartner Michael Lapzien.",
  },
];
---

<Layout title={title} description={description}>
  <section class="relative w-full py-12 md:py-16 bg-gradient-to-br from-blue-50 to-white border-b border-gray-100">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wide mb-4">
          <Briefcase class="h-4 w-4" />
          Karriere
        </div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text-main-light mb-4">Stellenangebote</h1>
        <p class="text-lg text-text-sub-light leading-relaxed">
          Werde Teil eines freundlichen Teams. Bei {BRAND.name} zählen Zuverlässigkeit, Respekt und saubere Arbeit – bei fairen Konditionen.
        </p>
      </div>
    </div>
  </section>

  <main class="py-12 md:py-20 min-w-0">
    <div class="mx-auto max-w-4xl min-w-0 px-4 sm:px-6 lg:px-8">
      <div class="grid min-w-0 gap-10 md:gap-14">
        <section class="rounded-2xl bg-white border border-gray-100 shadow-sm p-6 md:p-8 min-w-0 max-w-full">
          <h2 class="text-xl font-bold text-text-main-light mb-4">Das bieten wir dir</h2>
          <ul class="space-y-3 min-w-0">
            {benefits.map((line) => (
              <li class="flex min-w-0 items-start gap-3 text-text-sub-light">
                <CircleCheck class="h-5 w-5 text-primary shrink-0 mt-0.5" />
                <span class="min-w-0 break-words">{line}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 flex flex-wrap gap-x-4 gap-y-3 text-sm text-text-sub-light">
            <span class="flex min-w-0 max-w-full items-start gap-2">
              <Shield class="h-4 w-4 text-primary shrink-0 mt-0.5" />
              <span class="min-w-0 break-words">Betriebshaftpflicht & geprüftes Personal</span>
            </span>
            <span class="flex min-w-0 max-w-full items-start gap-2">
              <Clock class="h-4 w-4 text-primary shrink-0 mt-0.5" />
              <span class="min-w-0 break-words">Mo–Fr, Zeiten nach Absprache</span>
            </span>
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-text-main-light mb-6">Aktuelle Ausschreibungen</h2>
          <div class="space-y-6">
            {openings.map((job) => (
              <article class="rounded-2xl border border-gray-200 bg-surface-light p-6 md:p-8 hover:border-primary/30 transition-colors">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                  <h3 class="text-lg font-bold text-text-main-light">{job.title}</h3>
                  <span class="text-sm font-medium text-primary sm:whitespace-nowrap">{job.type}</span>
                </div>
                <p class="text-text-sub-light leading-relaxed">{job.text}</p>
              </article>
            ))}
          </div>
          <p class="mt-6 text-text-sub-light text-sm">
            Kein passendes Profil dabei? Initiativbewerbungen sind ausdrücklich willkommen – wir melden uns bei dir, sobald eine Stelle passt.
          </p>
        </section>

        <section class="rounded-2xl bg-primary text-white p-6 md:p-8 relative overflow-hidden">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
          <div class="relative z-10">
            <h2 class="text-xl font-bold mb-2">So bewirbst du dich</h2>
            <p class="text-blue-100 mb-6 max-w-2xl">
              Schick uns kurz deine Kontaktdaten und ob du Teilzeit oder Vollzeit anstrebst. Ein Lebenslauf im Anhang hilft uns – für ein erstes Gespräch ist er aber nicht zwingend.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">
              <a
                href={`mailto:${BRAND.email}?subject=Bewerbung%20${encodeURIComponent(BRAND.name)}`}
                class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-6 py-3 text-primary font-bold hover:bg-gray-100 transition-colors"
              >
                <Mail class="h-5 w-5" />
                Bewirb dich per E-Mail
              </a>
              <a
                href={`tel:${BRAND.phone.replace(/\s/g, "")}`}
                class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white px-6 py-3 font-bold text-white hover:bg-white/10 transition-colors"
              >
                <Phone class="h-5 w-5" />
                {BRAND.phone}
              </a>
              <a
                href={mobileTelHref}
                class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white px-6 py-3 font-bold text-white hover:bg-white/10 transition-colors"
              >
                <Smartphone class="h-5 w-5" />
                Mobil {BRAND.mobile}
              </a>
              <a
                href={whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex flex-col sm:flex-row items-center justify-center gap-1 sm:gap-2 rounded-lg bg-[#25D366] px-6 py-3 font-bold text-white hover:bg-[#20bd5a] transition-colors text-center"
              >
                <span class="inline-flex items-center gap-2">
                  <MessageCircle class="h-5 w-5 shrink-0" />
                  WhatsApp
                </span>
                <span class="text-sm font-semibold opacity-95">{BRAND.mobile}</span>
              </a>
            </div>
          </div>
        </section>

        <div>
          <a href="/#contact" class="inline-flex items-center gap-2 text-primary hover:text-primary-hover font-medium">
            Oder nutze das Kontaktformular auf der Startseite
            <ArrowRight class="h-4 w-4" />
          </a>
          <p class="mt-4">
            <a href="/" class="text-text-sub-light hover:text-primary transition-colors">← Zurück zur Startseite</a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
