---
import { Circle } from "lucide";
import Layout from "../layouts/Layout.astro";
import { Briefcase, Mail, Phone, MapPin, CircleCheck, Clock, Shield, ArrowRight } from "@lucide/astro";

const BRAND = {
  name: "EMSIG Gebäudedienste GmbH",
  email: "info@emsig-gd.de",
  phone: "+49 4621 930245",
  address: "Husumer Baum 36, 24837 Schleswig",
};

const title = `Stellenangebote – ${BRAND.name}`;
const description = `Karriere bei ${BRAND.name}: Jobs in der Gebäudereinigung in Schleswig-Holstein. Bewerben Sie sich jetzt – faire Bezahlung, festes Team, geprüfter Arbeitgeber.`;

const benefits = [
  "Faire Vergütung und pünktliche Auszahlung",
  "Einarbeitung durch erfahrene Kolleg:innen",
  "Geprüftes, freundliches Team",
  "Einsatz in Schleswig-Holstein (u. a. Schleswig, Kiel, Umgebung)",
];

const openings = [
  {
    title: "Reinigungskraft (m/w/d)",
    type: "Teilzeit / Vollzeit",
    text: "Unterhaltsreinigung in Büros, Praxen und Privathaushalten. Zuverlässigkeit und Sorgfalt sind uns wichtiger als lange Berufserfahrung – wir bringen Ihnen alles bei.",
  },
//  {
//    title: "Objektleitung / Teamleitung (m/w/d)",
//    type: "Nach Vereinbarung",
//    text: "Koordination der Einsätze, Qualitätssicherung und Ansprechpartner:in für Kund:innen. Erfahrung in der Reinigungsbranche oder vergleichbare Führungserfahrung von Vorteil.",
//  },
];
---

<Layout title={title} description={description}>
  <section class="relative w-full py-12 md:py-16 bg-gradient-to-br from-blue-50 to-white border-b border-gray-100">
    <div class="max-w-[1280px] mx-auto px-4 md:px-10">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wide mb-4">
          <Briefcase class="h-4 w-4" />
          Karriere
        </div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text-main-light mb-4">Stellenangebote</h1>
        <p class="text-lg text-text-sub-light leading-relaxed">
          Werden Sie Teil eines freundlichen Teams. Bei {BRAND.name} zählen Zuverlässigkeit, Respekt und saubere Arbeit – bei fairen Konditionen.
        </p>
      </div>
    </div>
  </section>

  <main class="py-12 md:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 md:gap-14">
        <section class="rounded-2xl bg-white border border-gray-100 shadow-sm p-6 md:p-8">
          <h2 class="text-xl font-bold text-text-main-light mb-4">Das bieten wir</h2>
          <ul class="space-y-3">
            {benefits.map((line) => (
              <li class="flex items-start gap-3 text-text-sub-light">
                <CircleCheck class="h-5 w-5 text-primary shrink-0 mt-0.5" />
                <span>{line}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 flex flex-wrap gap-4 text-sm text-text-sub-light">
            <span class="inline-flex items-center gap-2">
              <Shield class="h-4 w-4 text-primary" />
              Betriebshaftpflicht & geprüftes Personal
            </span>
            <span class="inline-flex items-center gap-2">
              <Clock class="h-4 w-4 text-primary" />
              Mo–Fr, Zeiten nach Absprache
            </span>
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-text-main-light mb-6">Aktuelle Ausschreibungen</h2>
          <div class="space-y-6">
            {openings.map((job) => (
              <article class="rounded-2xl border border-gray-200 bg-surface-light p-6 md:p-8 hover:border-primary/30 transition-colors">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                  <h3 class="text-lg font-bold text-text-main-light">{job.title}</h3>
                  <span class="text-sm font-medium text-primary whitespace-nowrap">{job.type}</span>
                </div>
                <p class="text-text-sub-light leading-relaxed">{job.text}</p>
              </article>
            ))}
          </div>
          <p class="mt-6 text-text-sub-light text-sm">
            Kein passendes Profil dabei? Initiativbewerbungen sind ausdrücklich willkommen – wir melden uns, sobald eine Stelle passt.
          </p>
        </section>

        <section class="rounded-2xl bg-primary text-white p-6 md:p-8 relative overflow-hidden">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
          <div class="relative z-10">
            <h2 class="text-xl font-bold mb-2">So bewerben Sie sich</h2>
            <p class="text-blue-100 mb-6 max-w-2xl">
              Senden Sie uns kurz Ihre Kontaktdaten und ob Sie Teilzeit oder Vollzeit anstreben. Ein Lebenslauf im Anhang hilft uns – ist aber nicht zwingend für ein erstes Gespräch.
            </p>
            <div class="flex flex-col sm:flex-row flex-wrap gap-4">
              <a
                href={`mailto:${BRAND.email}?subject=Bewerbung%20${encodeURIComponent(BRAND.name)}`}
                class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-6 py-3 text-primary font-bold hover:bg-gray-100 transition-colors"
              >
                <Mail class="h-5 w-5" />
                Per E-Mail bewerben
              </a>
              <a
                href={`tel:${BRAND.phone.replace(/\s/g, "")}`}
                class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white px-6 py-3 font-bold text-white hover:bg-white/10 transition-colors"
              >
                <Phone class="h-5 w-5" />
                {BRAND.phone}
              </a>
            </div>
          </div>
        </section>

        <section class="flex flex-col sm:flex-row gap-6 text-text-sub-light text-sm border-t border-gray-200 pt-8">
          <div class="flex items-start gap-3">
            <MapPin class="h-5 w-5 text-primary shrink-0" />
            <div>
              <p class="font-semibold text-text-main-light">Einsatz &amp; Büro</p>
              <p>{BRAND.address}</p>
            </div>
          </div>
        </section>

        <div>
          <a href="/#contact" class="inline-flex items-center gap-2 text-primary hover:text-primary-hover font-medium">
            Oder Kontaktformular auf der Startseite
            <ArrowRight class="h-4 w-4" />
          </a>
          <p class="mt-4">
            <a href="/" class="text-text-sub-light hover:text-primary transition-colors">← Zurück zur Startseite</a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
